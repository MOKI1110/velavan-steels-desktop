{
  "name": "velavan-steels-quotation",
  "version": "1.3.1",
  "description": "Quotation application for Velavan Steels",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "keywords": [],
  "author": "Mokith",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.mokith.velavan.steels",
    "productName": "Velavan Steels Quotation",
    "asar": false,
    "files": [
      "main.js",
      "preload.js",
      "web/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    }
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
